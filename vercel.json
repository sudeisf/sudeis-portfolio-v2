{
  "cleanUrls": true,
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/admin",
      "destination": "/#admin",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
