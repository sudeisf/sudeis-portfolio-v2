SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Cloudinary — fast image/video CDN
# 1. Add cloud name, API key, API secret
# 2. Create an UNSIGNED upload preset (Settings → Upload → Upload presets)
# 3. Set CLOUDINARY_UPLOAD_PRESET to that preset name for direct fast uploads
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET=""
